# Configuration du serveur
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Configuration Hedera
HEDERA_ACCOUNT_ID=0.0.123456
HEDERA_PRIVATE_KEY=your-private-key-here
HEDERA_NETWORK=testnet
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Configuration IPFS
IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API_URL=https://api.pinata.cloud
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# Configuration JWT
JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# Configuration de la base de données (optionnel)
DATABASE_URL=postgresql://username:password@localhost:5432/edu_chain
REDIS_URL=redis://localhost:6379

# Configuration des emails (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Configuration de sécurité
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuration des logs
LOG_LEVEL=info
LOG_FILE=logs/app.log