# Hedera Configuration
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.1234567
HEDERA_PRIVATE_KEY=your-private-key-here
HEDERA_PUBLIC_KEY=your-public-key-here

# IPFS Configuration
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
IPFS_PROJECT_ID=your-infura-project-id
IPFS_PROJECT_SECRET=your-infura-project-secret

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Database
MONGODB_URI=mongodb://localhost:27017/edu-chain-credentials

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-here
JWT_EXPIRES_IN=24h

# HashConnect Configuration
HASHCONNECT_APP_NAME=EduChain Credentials
HASHCONNECT_APP_DESCRIPTION=Certifications académiques décentralisées
HASHCONNECT_APP_ICON=https://edu-chain.dev/icon.png
HASHCONNECT_APP_URL=https://edu-chain.dev

# Email Configuration (pour notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin Configuration
ADMIN_EMAIL=admin@edu-chain.dev
ADMIN_PASSWORD=admin123456