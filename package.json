{
  "name": "educhain-credentials",
  "version": "1.0.0",
  "description": "Certification académique décentralisée sur Hedera Hashgraph",
  "main": "backend/src/server.js",
  "scripts": {
    "setup": "./scripts/setup.sh --full",
    "setup:check": "./scripts/setup.sh --check",
    "setup:install": "./scripts/setup.sh --install",
    "dev": "cd backend && npm run dev",
    "start": "cd backend && npm start",
