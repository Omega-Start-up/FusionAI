# ==============================================
# 🔶 FUSIONAI BACKEND - VARIABLES D'ENVIRONNEMENT
# ==============================================

# 🚀 Configuration Serveur
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# 🌐 URLs Frontend
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,https://fusionai.dev

# 🔐 JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# 🗄️ Base de Données PostgreSQL
DATABASE_URL=postgresql://fusionai:password@localhost:5432/fusionai_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fusionai_db
DB_USER=fusionai
DB_PASSWORD=password
DB_SSL=false

# 🔴 Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
REDIS_DB=0

# 📧 Configuration Email (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@fusionai.dev
SMTP_PASSWORD=your-email-password
EMAIL_FROM=FusionAI <noreply@fusionai.dev>

# 📁 Configuration Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt,zip

# 🔒 Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# 🌐 API Configuration
API_VERSION=v1
API_PREFIX=/api

# 🚀 Configuration Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:4200
SOCKET_PATH=/socket.io

# 🔧 Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 🐳 Docker Configuration
POSTGRES_DB=fusionai_db
POSTGRES_USER=fusionai
POSTGRES_PASSWORD=password

# 🔐 Sécurité
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-here

# 🌍 Internationalisation
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en

# 📊 Analytics (optionnel)
ANALYTICS_API_KEY=
SENTRY_DSN=

# ☁️ Cloud Storage (optionnel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=fusionai-uploads

# 🔧 Autres configurations
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true